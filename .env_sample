# OpenAI (Ignore if you don't use OpenAI AI models)
OPENAI_API_KEY=<your_openai_api_key>
# # Together.ai (Ignore if you don't use Together.ai AI models)
# TOGETHER_API_KEY=<your_together_api_key>
# # Google Cloud Platform (Ignore if you don't use Google AI models)
# GCP_PROJECT=<your_gcp_project>
# GCP_REGION=<your_gcp_region>
# GCP_CREDENTIALS=<your_gcp_credentials_path>

# From env name
MODEL_NAME="gpt-4.1-mini"

EMBEDDING_BACKEND=openai

# Use vLLM engine for chat
MODEL_NAME="gpt-4.1-mini"
AGENDA_MANAGER_MODEL_NAME="gpt-4.1-mini"
EXPLORATION_PLANNER_MODEL_NAME="gpt-4.1-mini"

# Agent
MAX_EVENTS_LEN=10
MAX_CONSIDERATION_ITERATIONS=4
USE_BASELINE_PROMPT="false"

# Exploration Planner (optional, defaults shown)
EXPLORATION_PLANNER_TURN_TRIGGER_MIN=2
EXPLORATION_PLANNER_NUM_ROLLOUTS=3
EXPLORATION_PLANNER_ROLLOUT_HORIZON=2
EXPLORATION_PLANNER_MAX_QUESTIONS=5
EXPLORATION_PLANNER_ALPHA=1
EXPLORATION_PLANNER_BETA=1
EXPLORATION_PLANNER_GAMMA=1
EXPLORATION_PLANNER_MIN_NOVELTY=0.6

# Evaluation
EVAL_MODE="false"
COMPLETION_METRIC="minimum_threshold"

# Directories
LOGS_DIR="logs"
DATA_DIR="data"
USER_AGENT_PROFILES_DIR="data/sample_user_profiles"
INTERVIEW_PLAN_PATH="data/configs/topics.json"
USER_PORTRAIT_PATH="data/configs/user_portrait.json"

# # Database (optional, only for server mode)
# DATABASE_URL="sqlite:///./data/interview_app.db"

# # AWS S3 (optional, for auto interviewer voice transcription)
# AWS_ACCESS_KEY_ID=<your_access_key_id>
# AWS_SECRET_ACCESS_KEY=<your_secret_access_key>
# AWS_BUCKET_NAME=<your_bucket_name>

# Interview Session (optional, default as follows)
SESSION_TIMEOUT_MINUTES=10
MEMORY_THRESHOLD_FOR_UPDATE=10

# Web app (candor_website / Flask). Used by src/main_flask.py.
# A random secret is auto-generated if unset, but set a fixed one in production.
FLASK_SECRET_KEY=<random_long_string>
TTS_PROVIDER=openai
TTS_VOICE=alloy

# ---------------------------------------------------------------------------
# Storage of finished-interview zip archives.
#   STORAGE_BACKEND: auto (default) | drive | vercel | both
#   auto -> Google Drive if configured (the current setup), else Vercel Blob if
#           BLOB_READ_WRITE_TOKEN is set, else keep data on local disk only.
# STORAGE_BACKEND=auto
#
# Post-interview Likert battery config (fixed validated set). Override to swap.
# LIKERT_BATTERY_PATH=data/configs/likert_battery.json
#
# --- Optional Vercel path (leave unset to stay on Google Drive) ---------------
# Vercel Blob: create a store and copy its read/write token.
# BLOB_READ_WRITE_TOKEN=
# VERCEL_BLOB_PREFIX=interviews
# Vercel Postgres / Neon (structured session metadata + Likert rows). Leave
# unset to skip DB writes — the app runs fine and answers still land in the zip.
# Requires uncommenting psycopg2-binary in requirements.txt.
# POSTGRES_URL=
# DATABASE_URL=
#
# On Vercel, POSTGRES_URL is required: the live interview is saved there between
# requests (there is no long-running server to hold it in memory). Set LOGS_DIR
# and DATA_DIR to /tmp on Vercel since the rest of the filesystem is read-only.
#
# Password for the admin conversation viewer at /admin. Leave unset to disable.
# ADMIN_PASSWORD=
# ---------------------------------------------------------------------------
# New agents (optional model overrides; default to MODEL_NAME).
# ENGAGEMENT_MONITOR_MODEL_NAME=gpt-4.1-mini   # quality/breakdown LLM gate
# CONTEXT_BIAS_MODEL_NAME=gpt-4.1-mini         # source bias analysis
#
# ---------------------------------------------------------------------------
# Optional: also/instead archive finished interviews to Google Drive.
# Leave unset to keep interview data on the server disk only.
# GDRIVE_FOLDER_ID is the id in the Drive folder URL
#   (drive.google.com/drive/folders/<GDRIVE_FOLDER_ID>).
# GDRIVE_FOLDER_ID=
#
# Auth: use OAUTH (recommended — files owned by your account, real storage
# quota; run scripts/get_oauth_token.py once to mint the refresh token):
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REFRESH_TOKEN=
#
# ...or a SERVICE ACCOUNT (only works uploading into a Shared Drive, since
# service accounts have no personal storage quota):
# GOOGLE_SERVICE_ACCOUNT_JSON=